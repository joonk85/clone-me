# Vite 클라이언트에 노출됨 (VITE_ 접두사)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 서버 전용 (Vercel 환경변수 등, 프론트에 넣지 말 것)
# SUPABASE_URL=                # 선택, API용. 없으면 VITE_SUPABASE_URL 사용
# SUPABASE_SERVICE_ROLE_KEY=
# ANTHROPIC_API_KEY=          # PDF/DOCX 추출 + voyage-3 임베딩 (/api/process-file)
# ANTHROPIC_EXTRACT_MODEL=    # 선택, 기본 claude-sonnet-4-20250514
# ANTHROPIC_EMBEDDING_MODEL=  # 선택, 기본 voyage-3
